{
    "extends": "../tsconfig.base.json",
    "compilerOptions": {
        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "outDir": "./dist",
        "rootDir": "./src",
        "noEmit": true,
        "isolatedModules": true,
        "allowImportingTsExtensions": true
    },
    "include": ["src/**/*"]
}
